# GitHub Integration
# Username to display on the /github dashboard
GITHUB_USERNAME=sahidattaf

# Optional: Personal Access Token (read-only, public repos only)
# Without this, the GitHub API allows 60 requests/hour per IP.
# With this, the limit increases to 5000 requests/hour.
# Generate at: https://github.com/settings/tokens
# Required scopes: none (public data only)
GITHUB_TOKEN=
